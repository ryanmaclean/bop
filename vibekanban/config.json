{
  "provider": "custom",
  "custom_provider": {
    "command": "nu ./vibekanban/bop-provider.nu",
    "poll_interval_ms": 2000,
    "cards_dir": ".cards"
  },
  "actions": {
    "retry": "jc --cards-dir .cards retry {id}",
    "kill":  "jc --cards-dir .cards kill {id}",
    "logs":  "jc --cards-dir .cards logs {id} --follow"
  },
  "columns": {
    "pending":     "Backlog",
    "in_progress": "In Progress",
    "review":      "Review",
    "done":        "Done",
    "blocked":     "Blocked"
  }
}
