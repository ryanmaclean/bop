(( $+functions[_jc_commands] )) ||
_jc_commands() {
    local commands; commands=(
'init:' \
'new:' \
'create:Create a new job draft from a natural-language description' \
'status:' \
'validate:' \
'dispatcher:' \
'merge-gate:' \
'retry:Move a card back to pending/ so the dispatcher picks it up again' \
'kill:Send SIGTERM to the running agent and mark the card as failed' \
'logs:Stream stdout and stderr logs for a card' \
'inspect:Show meta, spec, and a log summary for a card' \
'memory:Manage per-template persistent memory' \
'serve:Start the REST API server for CI/CD integration' \
'worktree:Manage git worktrees associated with job cards' \
'providers:Manage AI providers (list, add, remove, status)' \
'config:Read and write global/project config settings' \
'generate-completion:Generate shell completion script' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'jc commands' commands "$@"
}
