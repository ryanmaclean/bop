#compdef jc

autoload -U is-at-least

_jc() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'--cards-dir=[]:CARDS_DIR:_default' \
'-h[Print help]' \
'--help[Print help]' \
":: :_jc_commands" \
"*::: :->jc" \
&& ret=0
    case $state in
    (jc)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:jc-command-$line[1]:"
        case $line[1] in
            (init)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(new)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':template:_default' \
':id:_default' \
&& ret=0
;;
(create)
_arguments "${_arguments_options[@]}" : \
'--from-description=[Plain-language task description used to generate the card draft]:FROM_DESCRIPTION:_default' \
'--id=[Optional explicit id for the generated card]:ID:_default' \
'--yes[Skip confirmation prompt and write draft immediately]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(status)
