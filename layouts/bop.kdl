// bop.kdl — 7-pane Zellij layout for bop development
//
// Pane map (card lifecycle left → right, top → bottom):
//
//  ┌──────────┬──────────────────┬──────────────────┐
//  │  BOARD   │  SPEC            │  QA              │
//  │  watch   │  what to build   │  did it work?    │
//  │  status  ├──────────────────┼──────────────────┤
//  │          │  STDOUT          │  STDERR          │
//  │          │  agent output    │  agent errors    │
//  ├──────────┴──────────────────┴──────────────────┤
//  │  INSPECTOR — bop inspect <id>                  │
//  ├─────────────────────────────────────────────────┤
//  │  SHELL — bop commands (focus/retry/approve)    │
//  └─────────────────────────────────────────────────┘
//
// Launch: zellij --layout layouts/bop.kdl
// Focus:  Alt + arrow keys to move between panes
// Focus a card: bop_focus.nu <id>   (populates all panes)

layout {
    default_tab_template {
        children
        pane size=2 borderless=true {
            plugin location="zellij:status-bar"
        }
    }

    tab name="bop" focus=true {
        pane split_direction="horizontal" {

            // ── Top 60%: board (left) + stage pipeline (right) ──────────
            pane split_direction="vertical" size="60%" {

                // Board: auto-refreshing card list
                pane name="board" size="25%" {
                    command "sh"
                    args "-c" "ROOT=$(git rev-parse --show-toplevel 2>/dev/null || pwd); while true; do clear; $ROOT/target/debug/bop status 2>/dev/null || echo 'run: cargo build'; sleep 2; done"
                }

                // Stage pipeline: 2 rows × 2 columns
                // Row 1: SPEC (what to build) | QA (did it work?)
                // Row 2: STDOUT (agent live)  | STDERR (agent errors)
                pane split_direction="horizontal" {
                    pane split_direction="vertical" size="50%" {
                        pane name="spec" {
                            command "sh"
                            args "-c" "echo 'SPEC — run: bop_focus.nu <id>'; cat /tmp/.bop_card 2>/dev/null | xargs -I{} sh -c \"find .cards -name '{}.bop' 2>/dev/null | head -1 | xargs -I@ cat @/spec.md\" 2>/dev/null || zsh"
                        }
                        pane name="qa" {
                            command "sh"
                            args "-c" "echo 'QA — run: bop_focus.nu <id>'; zsh"
                        }
                    }
                    pane split_direction="vertical" size="50%" {
                        pane name="stdout" {
                            command "sh"
                            args "-c" "echo 'STDOUT — run: bop logs <id> --follow'; zsh"
                        }
                        pane name="stderr" {
                            command "sh"
                            args "-c" "echo 'STDERR — run: bop logs <id> --follow'; zsh"
                        }
                    }
                }
            }

            // ── Middle 25%: inspector ─────────────────────────────────
            pane name="inspector" size="25%" {
                command "sh"
                args "-c" "echo 'INSPECTOR — run: bop inspect <id>  or  bop_focus.nu <id>'; zsh"
            }

            // ── Bottom 15%: shell ─────────────────────────────────────
            pane name="shell" size="15%" {
                command "sh"
                args "-c" "ROOT=$(git rev-parse --show-toplevel 2>/dev/null || pwd); export PATH=$ROOT/target/debug:$PATH; zsh"
            }
        }
    }

    // Dispatch tab: run the engines directly
    tab name="dispatch" {
        pane split_direction="horizontal" {
            pane split_direction="vertical" size="75%" {
                pane name="dispatcher" {
                    command "sh"
                    args "-c" "ROOT=$(git rev-parse --show-toplevel 2>/dev/null || pwd); $ROOT/target/debug/bop dispatcher 2>&1 | tee /tmp/bop-dispatcher.log"
                }
                pane name="merge-gate" {
                    command "sh"
                    args "-c" "ROOT=$(git rev-parse --show-toplevel 2>/dev/null || pwd); $ROOT/target/debug/bop merge-gate 2>&1 | tee /tmp/bop-mergate.log"
                }
            }
            pane name="dispatch-shell" size="25%" {
                command "sh"
                args "-c" "ROOT=$(git rev-parse --show-toplevel 2>/dev/null || pwd); export PATH=$ROOT/target/debug:$PATH; zsh"
            }
        }
    }
}
