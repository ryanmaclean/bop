<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.yourorg.jobcard.merge-gate</string>
  
  <key>ProgramArguments</key>
  <array>
    <string>/usr/local/bin/bop</string>
    <string>merge-gate</string>
    <string>--poll-ms</string>
    <string>500</string>
  </array>
  
  <key>WorkingDirectory</key>
  <string>/Users/studio/gtfs</string>
  
  <key>EnvironmentVariables</key>
  <dict>
    <key>CARDS_DIR</key>
    <string>/Users/studio/gtfs/.cards</string>
  </dict>
  
  <key>KeepAlive</key>
  <true/>
  
  <key>RunAtLoad</key>
  <true/>
  
  <key>StandardOutPath</key>
  <string>/tmp/jobcard-merge-gate.log</string>
  
  <key>StandardErrorPath</key>
  <string>/tmp/jobcard-merge-gate.err</string>
  
  <key>HardResourceLimits</key>
  <dict>
    <key>NumberOfFiles</key>
    <integer>1024</integer>
  </dict>
  
  <key>SoftResourceLimits</key>
  <dict>
    <key>NumberOfFiles</key>
    <integer>512</integer>
  </dict>
</dict>
</plist>
